[Unit]
Description=FREE VOICE API
After=network.target mariadb.service

[Service]
Type=simple
User=www-data
Group=www-data
SupplementaryGroups={{ dendrite_group }}
WorkingDirectory=/opt/voip-api
EnvironmentFile=/etc/voip-api/env
Environment=UV_CACHE_DIR=/var/cache/voip-api-uv
ExecStart=/usr/local/bin/uv run --no-dev uvicorn main:app --host 127.0.0.1 --port 8000 --log-level warning
KillMode=mixed
KillSignal=SIGTERM
TimeoutStopSec=5
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
