{
  "name": "freevoice-client",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.ts",
    "test:e2e:real": "playwright test --config tests/e2e/playwright.real.config.ts",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:types": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint \"src/**/*.{js,ts,svelte}\"",
    "lint:fix": "eslint \"src/**/*.{js,ts,svelte}\" --fix",
    "format": "prettier --write 'src/**/*.{js,ts,svelte,css,html}'",
    "format:check": "prettier --check 'src/**/*.{js,ts,svelte,css,html}'",
    "validate:format": "npm run format:check",
    "validate:lint": "npm run lint",
    "validate:types": "npm run check:types",
    "validate:unit": "npm run test:unit",
    "validate:coverage": "npm run test:unit:coverage",
    "validate": "npm run format:check && npm run lint && npm run check && npm run test:unit"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.50.0",
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/svelte": "^5.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.16.0",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.3",
    "jsdom": "^25.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "livekit-client": "^2.17.3",
    "lucide-svelte": "^0.469.0",
    "matrix-js-sdk": "^34.0.0"
  }
}
